POLYMARKET_APP_NAME=polymarket-cli
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_API_BASE_URL=https://data-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
POLYMARKET_LOG_LEVEL=INFO
POLYMARKET_WORKDIR=.
POLYMARKET_DB_PATH=.local/state.db
POLYMARKET_WATCHLIST_CONFIG=config/watchlists.yaml
POLYMARKET_PROMPTS_DIR=config/prompts
POLYMARKET_RAW_DIR=data/raw
POLYMARKET_PROCESSED_DIR=data/processed
POLYMARKET_EXPORTS_DIR=exports
POLYMARKET_OLLAMA_BASE_URL=http://localhost:11434
POLYMARKET_OLLAMA_MODEL=gemma3:27b
POLYMARKET_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
POLYMARKET_OPENROUTER_MODEL=openai/gpt-4.1-mini
POLYMARKET_OPENROUTER_API_KEY=
